# ── App ──────────────────────────────────────────────────────
APP_NAME="Your App"
APP_ENV=production
APP_KEY=             # generate with: php artisan key:generate --show
APP_DEBUG=false
APP_URL=http://your-domain.com

# ── Database ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db           # matches the service name in docker-compose.yml
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret   # only needed by docker-compose

# ── Queue ────────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ── Cache / Session ──────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file


